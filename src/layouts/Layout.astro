---
import { join } from "node:path";
import { AstroFont } from "astro-font";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: Date;
  /** Writing pages render static — no entrance animation, content is just there */
  static?: boolean;
}

const {
  title,
  description = "Sam McClenaghan - Computer Science student at the University of Victoria and software engineer in Victoria, BC. Builds terminal tools and web apps, and writes about what building them taught him.",
  image = "/og/default.png",
  type = "website",
  publishedDate,
  static: isStatic = false,
} = Astro.props;

const siteName = "Sam McClenaghan";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image ? new URL(image, Astro.site) : null;

// JSON-LD Structured Data
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  author: {
    "@type": "Person",
    name: siteName,
  },
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteName,
  url: siteUrl,
  jobTitle: "Software Engineer",
  worksFor: {
    "@type": "Organization",
    name: "Vertical City",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "University of Victoria",
  },
};

const articleSchema =
  type === "article" && title && publishedDate
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description: description,
        url: canonicalURL.toString(),
        datePublished: publishedDate.toISOString(),
        author: {
          "@type": "Person",
          name: siteName,
          url: siteUrl,
        },
        publisher: {
          "@type": "Person",
          name: siteName,
          url: siteUrl,
        },
      }
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Mobile browser chrome color — kept in sync with the theme by the
         inline script below and footer.js -->
    <meta name="theme-color" content="#fff" />
    <!-- Inline theme detection to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const explicit =
          stored === "light" || stored === "dark" ? stored : null;
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const mode = explicit ?? (prefersDark ? "dark" : "light");
        document.documentElement.classList.toggle("dark", mode === "dark");
        document.documentElement.dataset.theme = mode;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", mode === "dark" ? "#121212" : "#fff");
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <ClientRouter />

    <AstroFont
      config={[
        {
          name: "Geist",
          src: [
            {
              style: "normal",
              weight: "100 900",
              path: join(process.cwd(), "public", "fonts", "geist-latin.woff2"),
            },
          ],
          preload: true,
          display: "swap",
          fallbackName: "Geist Fallback",
          fallback: "sans-serif",
        },
        {
          name: "Geist Mono",
          src: [
            {
              style: "normal",
              weight: "100 900",
              path: join(
                process.cwd(),
                "public",
                "fonts",
                "geist-mono-latin.woff2",
              ),
            },
          ],
          preload: true,
          display: "swap",
          fallbackName: "Geist Mono Fallback",
          fallback: "monospace",
        },
      ]}
    />
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={new URL("rss.xml", Astro.site)}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageURL ? "summary_large_image" : "summary"} />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- Article-specific meta -->
    {
      type === "article" && publishedDate && (
        <meta
          property="article:published_time"
          content={publishedDate.toISOString()}
        />
      )
    }

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    {
      articleSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(articleSchema)}
        />
      )
    }

  </head>
  <body>
    <div
      class="min-h-screen flex flex-col"
      id="page"
      data-static={isStatic ? "" : undefined}
    >
      <Header />
      <div class="w-full flex-1 flex flex-col mx-auto px-6 pb-8 max-w-2xl">
        <main class="flex-1">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

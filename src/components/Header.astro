---
// Two zones, one width: the pill sits exactly over the content column,
// the dot (which is the home link — no redundant "Home" label) on the
// left, destinations on the right. Same anatomy as the footer.
const links = [
  { href: "/writing", label: "Writing", section: "writing", key: "w" },
  { href: "/projects", label: "Projects", section: "projects", key: "p" },
];

const path = Astro.url.pathname;

function isCurrent(href: string) {
  return path === href || path.startsWith(`${href}/`);
}
---

<header class="sticky top-3 z-40 mt-3 mb-12 w-full max-w-2xl mx-auto px-6">
  <nav class="nav-pill flex items-center justify-between px-5 py-1.5">
    <a
      href="/"
      aria-label="Home"
      id="nav-dot"
      data-section="home"
      aria-keyshortcuts="h"
      class="touch-target group relative flex items-center"
    >
      <span
        class="relative size-6 rounded-full group-hover:scale-110"
        aria-hidden="true"></span>
      {
        path === "/" && (
          <span class="nav-underline nav-underline-dot" aria-hidden="true" />
        )
      }
    </a>
    <div class="flex items-center gap-7">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="nav-button text-item font-medium text-muted-foreground hover:text-foreground aria-[current=page]:text-foreground px-2 py-2.5 -mx-1 -my-1.5"
            aria-keyshortcuts={link.key}
            data-section={link.section}
            aria-current={isCurrent(link.href) ? "page" : undefined}
          >
            {link.label}
            {isCurrent(link.href) && (
              <span class="nav-underline" aria-hidden="true" />
            )}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script is:inline src="/scripts/header.js"></script>

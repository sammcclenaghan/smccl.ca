---

---

<header class="my-12" transition:persist>
  <nav class="flex items-center gap-8">
    <a
      href="/"
      class="nav-button text-muted-foreground hover:text-light-blue transition-colors duration-200 flex items-center gap-1 rounded-md px-1 py-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dark-blue"
      aria-keyshortcuts="h"
      data-section="home"
    >
      home
    </a>
    <a
      href="/blog"
      class="nav-button text-muted-foreground hover:text-light-blue transition-colors duration-200 flex items-center gap-1 rounded-md px-1 py-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dark-blue"
      aria-keyshortcuts="b"
      data-section="blog"
    >
      blog
    </a>
    <a
      href="/projects"
      class="nav-button text-muted-foreground hover:text-light-blue transition-colors duration-200 flex items-center gap-1 rounded-md px-1 py-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dark-blue"
      aria-keyshortcuts="p"
      data-section="projects"
    >
      projects
    </a>
  </nav>
</header>

<script>
  // Apply incremental fade-in to all .animate elements
  function applySequentialFade() {
    const elements = document.querySelectorAll<HTMLElement>(".animate");
    elements.forEach((el, i) => {
      el.style.setProperty("--i", String(i + 1));
      // Restart animation in case elements persist between transitions
      el.style.animation = "none";
      void el.offsetWidth; // reflow
      el.style.animation = "";
    });
  }

  // Show keycap from sessionStorage (persist across navigation)
  function showKeycapFromStorage() {
    const section = sessionStorage.getItem("keycap:section");
    const untilStr = sessionStorage.getItem("keycap:until");
    const until = untilStr ? parseInt(untilStr, 10) : 0;
    if (section && until > Date.now()) {
      const link = document.querySelector<HTMLAnchorElement>(
        `a[data-section="${section}"]`,
      );
      if (link) {
        link.classList.add("keycap-visible");
        const remaining = Math.max(0, until - Date.now());
        window.setTimeout(
          () => link.classList.remove("keycap-visible"),
          remaining,
        );
      }
    }
  }

  // Prepare stagger on the incoming document before swap
  function applySequentialFadeForDocument(doc: Document) {
    const elements = doc.querySelectorAll<HTMLElement>(".animate");
    elements.forEach((el, i) => {
      el.style.setProperty("--i", String(i + 1));
    });
  }

  // Initialize on page load and navigation
  document.addEventListener("DOMContentLoaded", () => {
    applySequentialFade();
    showKeycapFromStorage();
  });
  document.addEventListener("astro:page-load", () => {
    applySequentialFade();
    showKeycapFromStorage();
  });

  // Also re-assert after swap completes
  document.addEventListener("astro:after-swap", () => {
    showKeycapFromStorage();
    // Remove focus after SPA swap so focus ring doesn't remain
    if (document.activeElement instanceof HTMLElement) {
      document.activeElement.blur();
    }
  });

  // Ensure stagger is ready before the new DOM is swapped in SPA navigations
  document.addEventListener("astro:before-swap", (event: any) => {
    applySequentialFadeForDocument(event.newDocument as Document);
  });

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    if (e.defaultPrevented) return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;

    // Check if we're in an editable element
    const activeElement = document.activeElement;
    const tagName = activeElement?.tagName?.toLowerCase();
    const isEditable =
      tagName === "input" ||
      tagName === "textarea" ||
      (activeElement &&
        "isContentEditable" in activeElement &&
        activeElement.isContentEditable) ||
      tagName === "select";

    if (isEditable) return;

    const key = e.key?.toLowerCase();
    const keyToSection: Record<string, string> = {
      h: "home",
      b: "blog",
      p: "projects",
    };
    const section = keyToSection[key];
    if (section) {
      e.preventDefault();
      const link = document.querySelector<HTMLAnchorElement>(
        `a[data-section="${section}"]`,
      );
      if (link) {
        // Show the keycap hint briefly
        link.classList.add("keycap-visible");
        window.setTimeout(() => link.classList.remove("keycap-visible"), 600);
        link.click();
      }
    }
  });
</script>

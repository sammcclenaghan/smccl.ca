---
type Props = {
  name: string;
  href: string;
  description: string;
  lang: string;
};

const { name, href, description, lang } = Astro.props;
---

<li class="animate space-y-1">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="group flex items-baseline gap-3 py-1"
  >
    <span
      class="text-item font-medium inline-flex items-center gap-1.5 group-hover:text-accent transition-colors duration-200"
    >
      {name}
      <svg
        class="w-3 h-3 text-tx3 transition duration-200 group-hover:text-accent group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7 17L17 7M17 7H7M17 7V17"></path>
      </svg>
    </span>
    <span class="leader" aria-hidden="true"></span>
    <span class="meta shrink-0">{lang}</span>
  </a>
  <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
</li>

---
type Props = {
  name: string;
  href: string;
  description: string;
};

const { name, href, description } = Astro.props;
---

<li class="animate">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="group block space-y-1 py-1"
  >
    <span
      class="text-item font-medium inline-flex items-center gap-1.5 group-hover:text-accent transition-colors duration-200"
    >
      {name}
      <svg
        class="w-3 h-3 text-accent opacity-0 -translate-x-0.5 translate-y-0.5 transition duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7 17L17 7M17 7H7M17 7V17"></path>
      </svg>
    </span>
    <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
  </a>
</li>

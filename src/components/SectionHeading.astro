---
type Props = {
  title: string;
  as?: "h1" | "h2";
};

const { title, as: Tag = "h2" } = Astro.props;

// h1 = page title on subpages, h2 = section heading on home — same
// anatomy (star + title), two rungs of the same type ladder.
const titleClass = Tag === "h1" ? "text-2xl" : "text-lg";
const starClass = Tag === "h1" ? "text-2xl" : "text-xl";
---

<div class="animate section-heading flex items-center gap-2">
  <span class={`text-accent star ${starClass}`} aria-hidden="true">*</span>
  <Tag class={`${titleClass} font-semibold`}>{title}</Tag>
</div>

---
type Props = {
  title: string;
  as?: "h1" | "h2";
};

const { title, as: Tag = "h2" } = Astro.props;

// h1 = page title on subpages, h2 = section heading on home — two rungs
// of the same type ladder.
const titleClass = Tag === "h1" ? "text-2xl" : "text-lg";
---

<Tag class={`animate ${titleClass} font-semibold`}>{title}</Tag>

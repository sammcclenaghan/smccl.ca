---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
---

<Layout title="404">
  <div class="space-y-6 py-16" data-lost-dot>
    <SectionHeading title="404" as="h1" />
    <p class="animate text-sm text-muted-foreground leading-relaxed">
      This page doesn't exist.
    </p>
    <a href="/" class="quiet-link animate">
      Back home <span class="quiet-arrow">→</span>
    </a>
  </div>
</Layout>

<!-- The lost dot — on 404 only, the nav dot glances left and right,
     searching for the page. Then it goes looking for real: see the
     flight script below. Another dot job, same accent. -->
<style is:global>
  #nav-dot > span {
    animation: dot-lost 4s ease-in-out 1s infinite;
  }

  /* While the dot is away flying, its post sits empty — and the landing
     pulse needs to outrank the glance (both selectors carry the ID, so
     these win over the rule above) */
  #nav-dot.dot-away > span {
    animation: none;
    visibility: hidden;
  }

  #nav-dot.dot-arrive > span {
    animation: dot-arrive 350ms var(--ease-out);
  }

  @keyframes dot-lost {
    0%,
    40%,
    100% {
      transform: translateX(0);
    }
    8%,
    16% {
      transform: translateX(-4px);
    }
    24%,
    32% {
      transform: translateX(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #nav-dot > span {
      animation: none;
    }
  }
</style>

<script>
  // The fairy flight. After a couple of glances the dot slips out of the
  // nav, drifts down to inspect the "404", then — like a fairy leading you
  // to treasure — finds the Back home link, circles it twice, and bursts
  // into pixels. A moment later it's back at its post as if nothing
  // happened. The real anchor never moves; only its visual span hides
  // while a fixed-position clone does the flying, so keyboard and screen
  // reader users are untouched.

  const DOT_SIZE = 24; // matches the span's size-6

  let raf = 0;
  let sprites: HTMLElement[] = [];
  let timers: number[] = [];
  let flying = false;

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const easeInOut = (t: number) =>
    t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

  const center = (rect: DOMRect) => ({
    x: rect.left + rect.width / 2,
    y: rect.top + rect.height / 2,
  });

  function place(el: HTMLElement, x: number, y: number) {
    el.style.transform = `translate(${x - DOT_SIZE / 2}px, ${y - DOT_SIZE / 2}px)`;
  }

  function cleanup() {
    cancelAnimationFrame(raf);
    timers.forEach((t) => clearTimeout(t));
    timers = [];
    sprites.forEach((s) => s.remove());
    sprites = [];
    document.getElementById("nav-dot")?.classList.remove("dot-away");
    flying = false;
  }

  function spawnClone(x: number, y: number) {
    const clone = document.createElement("div");
    clone.setAttribute("aria-hidden", "true");
    clone.style.cssText = `position:fixed;left:0;top:0;width:${DOT_SIZE}px;height:${DOT_SIZE}px;border-radius:9999px;background:var(--accent);box-shadow:0 0 14px color-mix(in oklab, var(--accent) 55%, transparent);z-index:50;pointer-events:none;will-change:transform;`;
    place(clone, x, y);
    document.body.appendChild(clone);
    sprites.push(clone);
    return clone;
  }

  // Bursting into pixels: square particles, mostly accent with a few
  // brighter sparks, flung outward then settling like dust.
  function explode(x: number, y: number) {
    for (let i = 0; i < 18; i++) {
      const px = document.createElement("div");
      px.setAttribute("aria-hidden", "true");
      const size = Math.random() < 0.5 ? 2 : 3;
      const tint =
        i % 3 === 0
          ? "color-mix(in oklab, var(--accent) 55%, white)"
          : "var(--accent)";
      px.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:${size}px;height:${size}px;background:${tint};z-index:50;pointer-events:none;`;
      document.body.appendChild(px);
      sprites.push(px);

      const angle = (i / 18) * 2 * Math.PI + Math.random() * 0.6;
      const dist = 22 + Math.random() * 26;
      const dx = Math.cos(angle) * dist;
      const dy = Math.sin(angle) * dist;
      px.animate(
        [
          { transform: "translate(0, 0)", opacity: 1 },
          { transform: `translate(${dx}px, ${dy}px)`, opacity: 0.9, offset: 0.6 },
          { transform: `translate(${dx}px, ${dy + 18}px)`, opacity: 0 },
        ],
        {
          duration: 480 + Math.random() * 200,
          easing: "cubic-bezier(0.22, 1, 0.36, 1)",
          fill: "forwards",
        },
      );
    }
    timers.push(window.setTimeout(reappear, 650));
  }

  function reappear() {
    sprites.forEach((s) => s.remove());
    sprites = [];
    flying = false;
    const dot = document.getElementById("nav-dot");
    if (!dot) return;
    dot.classList.remove("dot-away");
    // Landing pulse via the shared gesture helper from header.js
    if (typeof playDotGesture === "function") {
      playDotGesture(dot, "dot-arrive");
    }
  }

  function fly() {
    const dot = document.getElementById("nav-dot");
    const dotSpan = dot?.querySelector("span");
    const heading = document.querySelector("main h1");
    const homeLink = document.querySelector("main .quiet-link");
    if (!dot || !dotSpan || !heading || !homeLink) {
      flying = false;
      return;
    }

    const start = center(dotSpan.getBoundingClientRect());
    const headingRect = heading.getBoundingClientRect();
    // Hover just past the 404's right shoulder while it "reads" the error
    const inspect = {
      x: headingRect.right + 28,
      y: headingRect.top + headingRect.height / 2,
    };
    const linkRect = homeLink.getBoundingClientRect();
    const linkC = center(linkRect);
    const rx = linkRect.width / 2 + 18;
    const ry = linkRect.height / 2 + 14;
    // The circling starts from the link's top edge, so segment three
    // lands there
    const entry = { x: linkC.x, y: linkC.y - ry };

    const clone = spawnClone(start.x, start.y);
    dot.classList.add("dot-away");

    const segments = [
      // Swoop down to the heading, dipping under the straight line
      {
        dur: 1000,
        at(t: number) {
          const e = easeInOut(t);
          return {
            x: lerp(start.x, inspect.x, e),
            y: lerp(start.y, inspect.y, e) + Math.sin(e * Math.PI) * 24,
          };
        },
      },
      // Hover and read (the wobble below does the acting)
      { dur: 700, at: () => ({ x: inspect.x, y: inspect.y }) },
      // Found it! Arc over to the Back home link
      {
        dur: 800,
        at(t: number) {
          const e = easeInOut(t);
          return {
            x: lerp(inspect.x, entry.x, e),
            y: lerp(inspect.y, entry.y, e) - Math.sin(e * Math.PI) * 16,
          };
        },
      },
      // Circle it twice, tightening — "here, this one"
      {
        dur: 1800,
        at(t: number) {
          const angle = -Math.PI / 2 + t * 4 * Math.PI;
          const decay = 1 - 0.15 * t;
          return {
            x: linkC.x + Math.cos(angle) * rx * decay,
            y: linkC.y + Math.sin(angle) * ry * decay,
          };
        },
      },
    ];

    let segIndex = 0;
    const t0 = performance.now();
    let segStart = t0;

    function frame(now: number) {
      const seg = segments[segIndex];
      const t = Math.min(1, (now - segStart) / seg.dur);
      const p = seg.at(t);
      // Fairies never travel in straight lines: a constant two-frequency
      // wobble rides on top of every segment
      const elapsed = now - t0;
      place(
        clone,
        p.x + Math.cos(elapsed / 260) * 2,
        p.y + Math.sin(elapsed / 170) * 3.5,
      );
      if (t >= 1) {
        segIndex += 1;
        segStart = now;
        if (segIndex >= segments.length) {
          clone.remove();
          explode(p.x, p.y);
          return;
        }
      }
      raf = requestAnimationFrame(frame);
    }
    raf = requestAnimationFrame(frame);
  }

  function launch() {
    if (flying) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    if (!document.querySelector("[data-lost-dot]")) return;
    flying = true;
    // Let the glance play a beat first — the flight is its payoff
    timers.push(window.setTimeout(fly, 2400));
  }

  document.addEventListener("astro:page-load", launch);
  document.addEventListener("astro:before-preparation", cleanup);
  launch();
</script>

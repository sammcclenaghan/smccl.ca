---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
---

<Layout>
  <div class="space-y-8">
    <div class="space-y-4 animate">
      <h1 class="font-medium text-3xl">
        <span class="text-blue-400 dark:text-blue-300">*</span> Projects 
      </h1>
    </div>

    <div class="space-y-4 pt-2">
      <div class="space-y-6">
        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/photograph"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              photograph
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            a photo gallery built with Next.js and UploadThing
          </p>
        </div>

        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/vikes-scraper"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              vikes scraper
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            course scraper using UVIC's public APIs to access course information
          </p>
        </div>

        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/TextAdventure"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              text adventure
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            event-driven game engine in Java with Factory and Command patterns
          </p>
        </div>

        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/git-fad"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              git-fad
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            git add with fuzzy searching capabilities
          </p>
        </div>

        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/mango"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              mango
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            a manga downloader built in Go
          </p>
        </div>

        <div class="space-y-2 animate group">
          <Link
            href="https://github.com/sammcclenaghan/mildred"
            external={true}
          >
            <h3 class="font-medium flex items-center gap-2">
              mildred
              <svg
                class="w-3 h-3 text-muted-foreground transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </h3>
          </Link>
          <p class="text-sm text-muted-foreground leading-relaxed">
            a more personal maid
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectRow from "../components/ProjectRow.astro";
import { projects } from "../data/projects";
---

<Layout title="Projects">
  <div class="space-y-6">
    <div class="space-y-3">
      <SectionHeading title="Projects" as="h1" />
      <p class="animate text-sm text-muted-foreground leading-relaxed">
        Things I've made — mostly terminal tools and small web apps.
      </p>
    </div>

    <ul class="space-y-4">
      {
        projects.map((project) => (
          <ProjectRow
            name={project.name}
            href={project.href}
            description={project.description}
            lang={project.lang}
          />
        ))
      }
    </ul>
  </div>
</Layout>

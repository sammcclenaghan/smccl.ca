---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PostRow from "../components/PostRow.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Writing">
  <div class="space-y-6">
    <div class="space-y-3">
      <SectionHeading title="Writing" as="h1" />
      <p class="animate text-sm text-muted-foreground leading-relaxed">
        Notes on things I've built and what I learned building them.
      </p>
    </div>

    {
      posts.length === 0 ? (
        <p class="animate text-muted-foreground">No writing yet.</p>
      ) : (
        <ul class="space-y-4">
          {posts.map((post) => (
            <PostRow
              href={`/writing/${post.id}`}
              title={post.data.title}
              date={post.data.date}
            />
          ))}
        </ul>
      )
    }
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PostRow from "../components/PostRow.astro";
import ProjectRow from "../components/ProjectRow.astro";
import { getCollection } from "astro:content";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<Layout>
  <div class="space-y-16 relative">
    <div class="space-y-6">
      <h1 class="animate font-semibold text-4xl">Sam McClenaghan</h1>
      <p class="animate leading-relaxed text-bio">
        I am a Computer Science student at the University of Victoria with
        experience building web applications and terminal tools. I'm passionate
        about creating efficient software solutions and exploring new
        technologies.
      </p>
    </div>

    <div class="space-y-6">
      <SectionHeading title="work" />

      <div class="animate space-y-1.5">
        <div class="flex items-baseline justify-between gap-4">
          <h3 class="font-medium">Vertical City</h3>
          <span class="meta shrink-0">May 2026 — Present</span>
        </div>
        <p class="text-sm text-muted-foreground">Software Engineer</p>
        <p class="text-sm leading-relaxed text-bio">
          Building backend systems that deliver content to digital signage in
          elevators and lobbies, with a focus on request handling, data usage,
          and keeping screens in sync.
        </p>
      </div>

      <div class="animate space-y-1.5">
        <div class="flex items-baseline justify-between gap-4">
          <h3 class="font-medium">Leanpub</h3>
          <span class="meta shrink-0">Jul — Dec 2025</span>
        </div>
        <p class="text-sm text-muted-foreground">Full Stack Developer Intern</p>
        <p class="text-sm leading-relaxed text-bio">
          Developed and maintained features for Leanpub's publishing platform,
          improving author and reader workflows with Ruby on Rails and React.
        </p>
      </div>

      <div class="animate space-y-1.5">
        <div class="flex items-baseline justify-between gap-4">
          <h3 class="font-medium">TrustScience</h3>
          <span class="meta shrink-0">Nov 2022 — Aug 2024</span>
        </div>
        <p class="text-sm text-muted-foreground">Software Engineer Intern</p>
        <p class="text-sm leading-relaxed text-bio">
          Built and enhanced financial integration workflows for client
          onboarding using Vue.js and AWS Lambda.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <SectionHeading title="writing" />

      <ul class="space-y-1.5">
        {
          posts.map((post) => (
            <PostRow
              href={`/writing/${post.id}`}
              title={post.data.title}
              date={post.data.date}
            />
          ))
        }
      </ul>

      <a href="/writing" class="quiet-link animate">
        all writing <span class="quiet-arrow">→</span>
      </a>
    </div>

    <div class="space-y-6">
      <SectionHeading title="projects" />

      {
        featured.map((project) => (
          <ProjectRow
            name={project.name}
            href={project.href}
            description={project.description}
          />
        ))
      }

      <a href="/projects" class="quiet-link animate">
        all projects <span class="quiet-arrow">→</span>
      </a>
    </div>
  </div>
</Layout>

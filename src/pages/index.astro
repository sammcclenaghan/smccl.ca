---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PostRow from "../components/PostRow.astro";
import ProjectRow from "../components/ProjectRow.astro";
import { getCollection } from "astro:content";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

---

<Layout>
  <div class="space-y-16 relative">
    <div class="space-y-6">
      <h1 class="animate font-semibold text-4xl">Sam McClenaghan</h1>
      <p class="animate leading-relaxed text-muted-foreground">
        I am a Computer Science student at the University of Victoria with
        experience building web applications and terminal tools. I'm passionate
        about creating efficient software solutions and exploring new
        technologies.
      </p>
    </div>

    <div class="space-y-6">
      <SectionHeading title="Work" />

      <div class="animate space-y-1">
        <h3 class="text-item font-medium">Vertical City</h3>
        <span class="meta block">May 2026 — Present</span>
        <p class="text-sm text-muted-foreground">Software Engineer</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Building backend systems that deliver content to digital signage in
          elevators and lobbies, with a focus on request handling, data usage,
          and keeping screens in sync.
        </p>
      </div>

      <div class="animate space-y-1">
        <h3 class="text-item font-medium">Leanpub</h3>
        <span class="meta block">May — Dec 2025</span>
        <p class="text-sm text-muted-foreground">Full Stack Developer Intern</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Worked in a large Rails monolith, rebuilding the Dropbox integration
          on AWS S3 and Redis-backed background jobs, with end-to-end progress
          tracking and RSpec coverage for critical publishing flows.
        </p>
      </div>

      <div class="animate space-y-1">
        <h3 class="text-item font-medium">Trustscience</h3>
        <span class="meta block">Jan — Aug 2024</span>
        <p class="text-sm text-muted-foreground">Application &amp; APIs Developer Intern</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Built a production file version-control system using HTTP/2 and JSON
          Patch for delta storage, cutting S3 costs 15%, plus a real-time
          analytics platform on DynamoDB and Elasticsearch that improved query
          performance 50%.
        </p>
      </div>

      <div class="animate space-y-1">
        <h3 class="text-item font-medium">Trustscience</h3>
        <span class="meta block">Nov 2022 — Aug 2023</span>
        <p class="text-sm text-muted-foreground">Frontend Developer Intern</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Modernized the front-end with Vue 3's Composition API and serverless
          AWS Lambda services, accelerating partner onboarding by 45%.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <SectionHeading title="Writing" />

      <ul class="space-y-4">
        {
          posts.map((post) => (
            <PostRow
              href={`/writing/${post.id}`}
              title={post.data.title}
              date={post.data.date}
            />
          ))
        }
      </ul>

      <a href="/writing" class="quiet-link animate">
        All writing <span class="quiet-arrow">→</span>
      </a>
    </div>

    <div class="space-y-6">
      <SectionHeading title="Projects" />

      <ul class="space-y-4">
        {
          featured.map((project) => (
            <ProjectRow
              name={project.name}
              href={project.href}
              description={project.description}
            />
          ))
        }
      </ul>

      <a href="/projects" class="quiet-link animate">
        All projects <span class="quiet-arrow">→</span>
      </a>
    </div>
  </div>
</Layout>

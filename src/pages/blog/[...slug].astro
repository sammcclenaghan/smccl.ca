---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedDate={post.data.date}
>
  <article class="space-y-8 prose-reading">
    <header class="space-y-3 animate">
      <h1 class="font-medium text-3xl">
        <span class="text-light-blue">✦</span> {post.data.title}
      </h1>
      <time class="text-tx3 text-sm block">{formatDate(post.data.date)}</time>
    </header>

    <div class="prose prose-lg dark:prose-invert max-w-prose animate">
      <Content />
    </div>
  </article>
</Layout>
